# Environment Configuration — DO NOT COMMIT .env

# Server
PORT=8002
HOST=0.0.0.0
DB_PATH=data/threat_intel.db

# AI Engine (choose one)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=

# Threat Intelligence APIs
RANSOMWARE_LIVE_API_KEY=your_key_here
ENABLE_RANSOMWARE_API=true
HIBR_API_KEY=your_hibr_key_here
ENABLE_HIBR=true
ABUSEIPDB_API_KEY=your_key_here
THREATFOX_API_KEY=your_key_here

# Dark Web / Tor
ENABLE_DARKWEB=true
TOR_SOCKS_PORT=9050

# Admin credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASS=change_this_to_secure_password

# Auto-run all intelligence feeds on startup
AUTO_RUN_ALL_ON_STARTUP=true
